# Offline Wallet backend — environment (dev). Copy to `.env`; never commit real secrets.
# See ARCHITECTURE.md §12 (Deployment & Environments).

NODE_ENV=development
PORT=3000

# PostgreSQL (system of record). Docker Compose / local managed instance.
# `npm run migrate` applies migrations/*.sql; the server also applies them
# at startup (fail-fast, see src/index.ts). NODE_ENV=test defaults to
# offline_wallet_test instead (see platform/config.ts) so `npm test` never
# touches dev data — override either with DATABASE_URL if your setup differs.
DATABASE_URL=postgres://wallet:wallet@localhost:5432/offline_wallet

# Bank Issuer signing key — dev only (encrypted local secret). Prod uses KMS/HSM.
# Populated in a later issuance task; only the PUBLIC key ever ships in the app.
ISSUER_KEY_ID=dev-issuer-1

# Firebase Admin (identity verification, FR-ID-01). Defaults to
# offline-wallet-ab2fc (the mobile app's project) if left blank.
FIREBASE_PROJECT_ID=

# Service account credentials for the Firebase Admin SDK — REQUIRED in
# production (the server fails fast at startup without one); optional
# outside production, where the server falls back to a project-id-only dev
# mode (ID token signature/expiry/issuer/audience verification still works,
# revocation checks are skipped). Set exactly ONE of the two below:
#   - FIREBASE_SERVICE_ACCOUNT_JSON: the service account key's JSON contents,
#     inline as a single-line string (handy for platforms without file mounts).
#   - GOOGLE_APPLICATION_CREDENTIALS: path to the service account key file
#     (standard Google Cloud convention).
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
