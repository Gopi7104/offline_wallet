  "description": "Offline Digital Cash Wallet — backend (modular monolith, hexagonal). Architecture v1.1.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "migrate": "ts-node src/platform/migrate_cli.ts",
    "test": "jest --runInBand",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "firebase-admin": "^14.1.0",
