<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (HTTP) is permitted ONLY for local development backends. Every
  domain not listed here stays secure-by-default (Android blocks cleartext on
  API 28+), so production HTTPS traffic is unaffected. Add/adjust dev IPs here.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Physical device → this dev Mac's LAN IP -->
        <domain includeSubdomains="false">10.205.185.61</domain>
        <!-- Android emulator → host-loopback alias -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Local loopback -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
